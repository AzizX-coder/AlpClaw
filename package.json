{
  "name": "splash",
  "version": "0.2.0",
  "private": true,
  "description": "Splash — Autonomous Agent Platform",
  "author": "Splash",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "splash": "./bin/splash.mjs",
    "alpclaw": "./bin/alpclaw.mjs"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/ examples/ --ext .ts",
    "format": "prettier --write \"packages/**/*.ts\" \"examples/**/*.ts\"",
    "clean": "pnpm -r run clean",
    "dev": "tsx examples/cli.ts"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "ink": "^5.0.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "picocolors": "^1.1.1",
    "react": "^18.3.1",
    "telegraf": "^4.16.3"
  }
}
